{
  "include": ["**/*.{ts,tsx,js,jsx}"],
  "exclude_patterns": [
    "**/generated/**",
    "**/vendor/**",
    "**/__mocks__/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/tests/**"
  ],
  "confidence_threshold": "MEDIUM",
  "out_dir": "docs/audits/codebase-map",
  "module_roots": [
    { "path": "apps", "depth": 1 },
    { "path": "packages", "depth": 1 },
    { "path": "services/api-ts/src/handlers", "depth": 1 },
    { "path": "specs", "depth": 1 }
  ],
  "module_depth": 1,
  "hono_route_tables": [
    "services/api-ts/src/generated/openapi/routes.ts",
    "services/api-ts/src/generated/openapi/registry.ts",
    "services/api-ts/src/generated/websocket/registry.ts"
  ],
  "sdk_operation_sources": [
    "packages/sdk-ts/src/generated/sdk.gen.ts",
    "packages/sdk-ts/src/generated/@tanstack/react-query.gen.ts"
  ],
  "sdk_import_specifiers": ["@monobase/sdk-ts"],
  "data_model_sources": [
    "services/api-ts/src/generated/better-auth/schema.ts"
  ],
  "spec_sources": [
    "specs/api/dist/openapi/openapi.json"
  ],
  "plugins": ["react"],
  "engine": {
    "binary_path": "/Users/elad-mini/Desktop/oli-engine/dist/cli.js"
  }
}
