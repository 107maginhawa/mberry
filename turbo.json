{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.local", "services/api-ts/.env"],
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "TZ",
    "PORT",
    "SERVER_PORT",
    "DATABASE_URL",
    "AUTH_SECRET",
    "BETTER_AUTH_SECRETS",
    "INTERNAL_SERVICE_TOKEN",
    "STORAGE_PROVIDER",
    "STORAGE_ENDPOINT",
    "STORAGE_BUCKET",
    "STORAGE_ACCESS_KEY_ID",
    "STORAGE_SECRET_ACCESS_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_URL",
    "ONESIGNAL_APP_ID",
    "ONESIGNAL_API_KEY",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "POSTMARK_API_KEY",
    "VITE_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^generate", "generate"],
      "outputs": ["dist/**", "build/**", "!.next/cache/**"]
    },
    "generate": {
      "dependsOn": ["^build"],
      "outputs": ["src/generated/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^build", "^generate", "generate"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build", "^generate", "generate"]
    },
    "lint": {
      "dependsOn": ["^build", "^generate", "generate"]
    },
    "test": {
      "dependsOn": ["^build", "^generate", "generate"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build", "^generate", "generate"],
      "cache": false
    }
  }
}
