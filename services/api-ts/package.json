{
  "name": "@monobase/api-ts",
  "version": "0.1.0",
  "description": "Monobase Application Platform API Service",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts",
    "./core/config": "./src/core/config.ts",
    "./core/database": "./src/core/database.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build --compile --minify --sourcemap --external ajv --external ajv-draft-04 src/index.ts --outfile dist/server",
    "generate": "bun scripts/generate.ts",
    "db:generate": "bash scripts/drizzle-wasm.sh generate",
    "db:seed": "bun run src/seed.ts",
    "db:studio": "bash scripts/drizzle-wasm.sh studio",
    "test": "bun test src/**/*.test.ts",
    "test:unit": "bun test src/**/*.test.ts",
    "test:integration": "bun test src/tests/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@better-auth/api-key": "1.6.11",
    "@better-auth/passkey": "1.6.11",
    "@aws-sdk/client-s3": "^3.879.0",
    "@aws-sdk/s3-request-presigner": "^3.879.0",
    "@hono/zod-openapi": "^0.18.0",
    "@hono/zod-validator": "^0.4.0",
    "@monobase/api-spec": "workspace:*",
    "@onesignal/node-onesignal": "^5.2.1-beta1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.66.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.207.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-node": "^0.207.0",
    "@scalar/hono-api-reference": "^0.9.16",
    "@vvo/tzdb": "^6.186.0",
    "better-auth": "1.6.11",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "handlebars": "^4.7.8",
    "hono": "^4.0.0",
    "i18n-iso-countries": "^7.14.0",
    "iso-639-1": "^3.1.5",
    "libphonenumber-js": "^1.12.24",
    "nodemailer": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "pg": "^8.16.3",
    "pg-boss": "^10.3.2",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.7",
    "postmark": "^4.0.5",
    "qrcode-svg": "^1.1.0",
    "stripe": "^19.1.0",
    "uuid": "^11.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "@monobase/eslint-config": "workspace:*",
    "@monobase/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.1",
    "@types/pg": "^8.15.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "nanoid": "^5.1.6",
    "typescript": "^5.7.0",
    "ws": "^8.18.3"
  }
}
