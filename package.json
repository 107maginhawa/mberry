{
  "name": "monobase",
  "version": "0.1.1.0",
  "private": true,
  "description": "Monobase Application Platform Monorepo",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "specs/*"
  ],
  "packageManager": "bun@1.2.21",
  "scripts": {
    "build": "bun run --filter '*' build",
    "clean": "rm -rf node_modules bun.lock && find . -name 'node_modules' -type d -prune -exec rm -rf {} +",
    "dev": "turbo run dev",
    "generate": "turbo run generate",
    "infra:up": "docker compose up -d --wait",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d --wait",
    "infra:logs": "docker compose logs -f",
    "lint:migrations": "bun scripts/migration-safety.ts",
    "lint:no-skips": "bun scripts/lint-no-skips.ts",
    "lint:shallow": "bun scripts/lint-shallow-tests.ts",
    "lint:e2e-depth": "bun run scripts/audit-e2e-depth.ts > /tmp/e2e-depth.json && bun run scripts/audit-e2e-depth-gate.ts",
    "audit:workflows": "bun scripts/audit/coverage-matrix.ts --gate && bun run lint:e2e-depth",
    "lint:handler-verbs": "bun run scripts/lint-handler-verbs.ts",
    "check:hand-wired-routes": "bun run scripts/check-hand-wired-routes.ts",
    "check:sdk-compat": "bun run scripts/check-sdk-compat.ts",
    "rollback": "bash scripts/rollback.sh",
    "test:sanity": "cd apps/memberry && CI=1 bunx playwright test _golden-path.spec.ts --workers=1 --reporter=line",
    "test:contract": "bun scripts/run-contract-tests.ts",
    "test:contract:full": "docker compose up -d mailpit stripe-mock --wait && bun scripts/run-contract-tests.ts",
    "test:br": "bun run scripts/br-coverage.ts",
    "test:contract:fuzz": "bun scripts/run-schemathesis.ts",
    "prepare": "husky",
    "test:registry": "bun run testing/registry/report.ts",
    "test:inventory": "bun run testing/scripts/generate-endpoint-inventory.ts && bun run testing/scripts/generate-screen-inventory.ts && bun run testing/scripts/generate-component-inventory.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "update:scorecard": "bun run scripts/update-scorecard.ts"
  },
  "lint-staged": {
    "services/api-ts/**/*.{ts,tsx}": [
      "services/api-ts/node_modules/.bin/eslint --fix --quiet --config services/api-ts/eslint.config.js"
    ],
    "apps/memberry/**/*.{ts,tsx}": [
      "apps/memberry/node_modules/.bin/eslint --fix --quiet --config apps/memberry/eslint.config.js"
    ],
    "apps/admin/**/*.{ts,tsx}": [
      "apps/admin/node_modules/.bin/eslint --fix --quiet --config apps/admin/eslint.config.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.2.21"
  },
  "overrides": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "csstype": "3.2.3",
    "@playwright/test": "1.58.2",
    "playwright": "1.58.2",
    "playwright-core": "1.58.2",
    "esbuild": "^0.28.0",
    "form-data": ">=4.0.6",
    "@opentelemetry/core": ">=2.8.0"
  },
  "devDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.52.3",
    "@rollup/rollup-linux-x64-gnu": "^4.52.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "react-hook-form": "^7.75.0",
    "turbo": "^2.3.3"
  },
  "dependencies": {
    "esbuild": "^0.28.0",
    "hono": "^4.12.26"
  }
}
