# Memberry Platform — Root Environment Configuration
#
# This is a pointer file. The comprehensive .env.example lives in:
#   services/api-ts/.env.example
#
# Quick start:
#   1. cp services/api-ts/.env.example services/api-ts/.env
#   2. Edit services/api-ts/.env with your local values
#   3. bun run dev:deps:up   (starts Postgres + MinIO)
#   4. cd services/api-ts && bun dev
#
# Required for local development (minimum):
TZ=UTC
DATABASE_URL=postgres://postgres:password@localhost:5432/monobase
AUTH_SECRET=local-dev-secret-change-in-production
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=memberry-dev
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin

# See services/api-ts/.env.example for all options:
# - Email (SMTP/Postmark/OneSignal)
# - Billing (Stripe)
# - Google OAuth
# - Notifications
# - WebRTC
